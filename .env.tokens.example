# ──────────────────────────────────────────────────────────────────────────────
# VantaDB — Tokens & Secrets Template
# ──────────────────────────────────────────────────────────────────────────────
# Copia este archivo a `.env.tokens` (está en .gitignore) y completa los
# valores reales. Cada sección indica dónde se usa cada token.
# ──────────────────────────────────────────────────────────────────────────────

# ── 1. VantaDB Server ─────────────────────────────────────────────────────────
# Usado en: src/config.rs, src/cli_server.rs
# Protege endpoints HTTP con autenticación Bearer.
# VANTADB_API_KEY=""

# Clave de cifrado AES-256-GCM para datos en reposo (64 hex chars = 32 bytes).
# Usado en: src/crypto.rs, src/config.rs (feature "encryption")
# Generar con: openssl rand -hex 32
# VANTADB_ENCRYPTION_KEY=""

# ── 2. API Keys de Embeddings/LLM (programáticos) ─────────────────────────────
# Se pasan como argumentos al constructor de cada adapter, no como env vars.
# Usado en: vantadb-openai/src/python.rs
# VantaDBOpenAI(db_path, api_key="sk-...", model="text-embedding-3-small")

# Usado en: vantadb-litellm/src/python.rs
# VantaDBLiteLLM(db_path, api_key="...", model="text-embedding-3-small")

# ── 3. PyPI Publishing ────────────────────────────────────────────────────────
# Usado en: .github/workflows/python_wheels.yml
# Se usa OIDC trusted publishing (no requiere token estático).
# Solo necesitas:
#   - Entorno "pypi" configurado en GitHub con OIDC
#   - Entorno "testpypi" configurado en GitHub con OIDC
#   - PyPI project registrado: https://pypi.org/manage/project/vantadb-py/
#   - TestPyPI project registrado: https://test.pypi.org/manage/project/vantadb-py/
# Para adapters:
#   - vantadb-langchain, vantadb-llamaindex, etc. en PyPI
#   - Mismo mecanismo OIDC, pero cada uno necesita su environment.

# ── 4. npm Publishing ─────────────────────────────────────────────────────────
# Usado en: vantadb-ts/
# npm token para publicar el package TypeScript.
# Generar en: https://www.npmjs.com/settings/<user>/tokens
# NPM_TOKEN=""

# ── 5. GitHub Secrets (Actions) ───────────────────────────────────────────────
# Configurados en: https://github.com/ness-e/Vantadb/settings/secrets/actions
# Automáticos (no requieren configuración manual):
#   - secrets.GITHUB_TOKEN  → release.yml (upload assets)
#   - github.token (GH_TOKEN) → python_wheels.yml (attestation verify)
#   - id-token: write       → OIDC trusted publishing (no es secret estático)

# ── 6. Discord ────────────────────────────────────────────────────────────────
# Usado en: Community
# Invite link del servidor Discord de VantaDB.
# DISCORD_INVITE="https://discord.gg/..."

# ── 7. Vercel ──────────────────────────────────────────────────────────────────
# Usado en: web/ (deploy automático)
# OIDC Token para deploy desde CI.
# (Ya existe en .env.local y web/.env.local — ignorados por git)
# VERCEL_OIDC_TOKEN=""

# ── 8. OpenTelemetry (opcional) ────────────────────────────────────────────────
# Usado en: src/cli_server.rs (feature "opentelemetry")
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
# OTEL_SERVICE_NAME="vantadb-server"

# ── 9. Storage Backend ─────────────────────────────────────────────────────────
# Usado en: src/config.rs
# VANTADB_STORAGE_PATH="./vantadb_data"
# VANTA_BACKEND="fjall"          # fjall | rocksdb | memory

# ── 10. TLS (opcional) ─────────────────────────────────────────────────────────
# Usado en: src/config.rs (feature "tls")
# VANTADB_TLS_CERT="./cert.pem"
# VANTADB_TLS_KEY="./key.pem"

# ── 11. LLM Server ─────────────────────────────────────────────────────────────
# Usado en: src/config.rs, src/llm.rs
# VANTA_LLM_URL="http://localhost:11434"
# VANTA_LLM_MODEL="all-minilm"
# VANTA_LLM_SUMMARIZE_MODEL="llama3"

# ── 12. Performance Tuning ────────────────────────────────────────────────────
# Usado en: src/config.rs, src/index/core.rs
# VANTADB_RATE_LIMIT_RPM="100"
# VANTADB_MAX_BLOCKING_THREADS="16"
# VANTADB_WAL_SHARDS="4"
# VANTADB_FLUSH_THRESHOLD="10000"
# VANTADB_WAL_BUFFER_SIZE="65536"
# VANTA_PREFETCH="auto"          # enabled | disabled | auto
