---
import VantaDBLogo from "../react/VantaDBLogo.tsx";
---

<header class="fixed top-0 left-0 right-0 z-50" style="background: var(--surface-glass); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border);">
  <nav class="mx-auto px-6 h-14 flex items-center justify-between" style="max-width: 1280px;">
    <a href="/" class="flex items-center gap-2 no-underline hover:opacity-80 transition-opacity">
      <VantaDBLogo variant="mark" size="sm" client:load />
      <span class="font-display text-lg font-bold tracking-tight">Vanta<span style="color: var(--amber);">DB</span></span>
    </a>

    <div class="hidden md:flex items-center gap-8" style="font-family: var(--font-mono); font-size: var(--text-label); text-transform: uppercase; letter-spacing: 0.14em;">
      <a href="/#features" class="nav-link">Features</a>
      <a href="/#showcase" class="nav-link">Showcase</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/#integrations" class="nav-link">Integrations</a>
    </div>

    <div class="flex items-center gap-4">
      <a href="https://github.com/vantadb/vantadb" class="nav-link hidden sm:inline" style="font-family: var(--font-mono); font-size: var(--text-label); text-transform: uppercase;">
        GitHub
      </a>
      <button class="btn-primary text-sm px-5 py-2" style="font-family: var(--font-mono); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; background: var(--amber); color: var(--white); border: none; cursor: pointer;">
        Get Started
      </button>
    </div>

    <button class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
      <span class="block w-5 h-[1.5px] bg-current transition-transform"></span>
      <span class="block w-5 h-[1.5px] bg-current transition-opacity"></span>
      <span class="block w-5 h-[1.5px] bg-current transition-transform"></span>
    </button>
  </nav>
</header>

<style>
  .nav-link {
    color: var(--muted);
    transition: color 0.15s var(--ease-brutal);
    text-decoration: none;
  }
  .nav-link:hover {
    color: var(--foreground);
  }
  .btn-primary {
    transition: all 0.15s var(--ease-brutal);
  }
  .btn-primary:hover {
    background: var(--amber-light);
  }
</style>
