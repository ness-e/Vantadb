---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, author, tags } = post.data;
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto px-6 pt-28 pb-16" style="max-width: 720px;">
    <a href="/blog" class="text-xs mb-8 inline-block" style="font-family: var(--font-mono); color: var(--muted); text-transform: uppercase; letter-spacing: 0.14em; text-decoration: none;">
      &larr; Back to Blog
    </a>

    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <time class="text-xs" style="font-family: var(--font-mono); color: var(--steel);">
          {pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        <span class="text-xs" style="font-family: var(--font-mono); color: var(--muted);">by {author}</span>
        {tags?.map((tag) => (
          <span class="text-xs px-2 py-0.5" style="font-family: var(--font-mono); color: var(--amber); background: var(--amber-dim);">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="font-display font-bold leading-tight tracking-tight" style="font-size: var(--text-display);">{title}</h1>
      <p class="mt-4" style="color: var(--muted); font-size: var(--text-body);">{description}</p>
    </header>

    <div class="prose-custom">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .prose-custom :deep(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-custom :deep(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-custom :deep(p) {
    margin-bottom: 1.25rem;
    line-height: 1.75;
    color: var(--muted);
  }
  .prose-custom :deep(code) {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--amber);
  }
  .prose-custom :deep(pre) {
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    overflow-x: auto;
    background: var(--terminal-bg);
    border: 1px solid var(--border);
  }
  .prose-custom :deep(pre code) {
    color: var(--foreground);
    font-size: 0.82rem;
    line-height: 1.6;
  }
  .prose-custom :deep(ul) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: var(--muted);
  }
  .prose-custom :deep(li) {
    margin-bottom: 0.5rem;
  }
  .prose-custom :deep(strong) {
    color: var(--foreground);
  }
  .prose-custom :deep(a) {
    color: var(--amber);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-custom :deep(blockquote) {
    border-left: 3px solid var(--amber);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--muted);
    font-style: italic;
  }
  .prose-custom :deep(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }
</style>
