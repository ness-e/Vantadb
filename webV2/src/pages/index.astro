---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/react/Hero.tsx";
import Stats from "../components/react/Stats.tsx";
import Features from "../components/react/Features.tsx";
import Showcase from "../components/react/Showcase.tsx";
import HowItWorks from "../components/react/HowItWorks.tsx";
import Integrations from "../components/react/Integrations.tsx";
import CTA from "../components/react/CTA.tsx";
---

<BaseLayout title="VantaDB" description="The database that thinks with you. One binary. Three query engines. Zero ops.">
  <Hero client:load />
  <Stats client:visible />
  <Features client:visible />
  <Showcase client:visible />
  <HowItWorks client:visible />
  <Integrations client:visible />
  <CTA client:visible />
</BaseLayout>
