{
  "__inputs": [],
  "__requires": [],
  "dashboard": {
    "title": "VantaDB Operations",
    "tags": ["vantadb", "operations"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "panels": [
      {
        "title": "Memory & RSS",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "decbytes"
          }
        },
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=~\"vantadb.*\"}",
            "legendFormat": "RSS {{instance}}"
          },
          {
            "expr": "vantadb_rss_bytes{job=~\"vantadb.*\"}",
            "legendFormat": "VantaDB RSS {{instance}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "title": "Memory Pressure (80% trigger)",
        "type": "gauge",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 0.7 },
                { "color": "red", "value": 0.8 }
              ]
            }
          }
        },
        "targets": [
          {
            "expr": "vantadb_memory_pressure_ratio{job=~\"vantadb.*\"}",
            "legendFormat": "Pressure {{instance}}"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
      },
      {
        "title": "Vector Operations / sec",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "rate(vantadb_vector_ops_total{job=~\"vantadb.*\"}[1m])",
            "legendFormat": "{{operation}} {{instance}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "title": "Query Latency P50/P95/P99",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(vantadb_query_duration_seconds_bucket{job=~\"vantadb.*\"}[5m]))",
            "legendFormat": "P50 {{instance}}"
          },
          {
            "expr": "histogram_quantile(0.95, rate(vantadb_query_duration_seconds_bucket{job=~\"vantadb.*\"}[5m]))",
            "legendFormat": "P95 {{instance}}"
          },
          {
            "expr": "histogram_quantile(0.99, rate(vantadb_query_duration_seconds_bucket{job=~\"vantadb.*\"}[5m]))",
            "legendFormat": "P99 {{instance}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
      },
      {
        "title": "Disk Usage Per Shard",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "decbytes"
          }
        },
        "targets": [
          {
            "expr": "vantadb_storage_bytes{job=~\"vantadb.*\"}",
            "legendFormat": "{{backend}} {{instance}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
      },
      {
        "title": "Index Memory (Quantized vs Full)",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "decbytes"
          }
        },
        "targets": [
          {
            "expr": "vantadb_index_memory_bytes{layer=~\"L1|L2|L2_5|L3\",job=~\"vantadb.*\"}",
            "legendFormat": "{{layer}} {{instance}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
      }
    ]
  }
}
