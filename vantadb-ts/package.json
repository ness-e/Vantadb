{
  "name": "vantadb",
  "version": "0.3.0",
  "description": "VantaDB TypeScript SDK — WASM-powered embedded vector & graph memory for JS runtimes (Node, Bun, Deno, browser)",
  "type": "module",
  "main": "dist/vantadb.js",
  "types": "dist/vantadb.d.ts",
  "exports": {
    ".": {
      "types": "./dist/vantadb.d.ts",
      "import": "./dist/vantadb.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ness-e/Vantadb.git"
  },
  "homepage": "https://vantadb.dev",
  "bugs": "https://github.com/ness-e/Vantadb/issues",
  "keywords": [
    "vector-database",
    "memory",
    "rag",
    "embeddings",
    "graph",
    "wasm",
    "ai",
    "semantic-search"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "vantadb-wasm": "file:../vantadb-wasm/pkg"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^3.1.3"
  }
}
