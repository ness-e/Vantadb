{
  "name": "vantadb-website",
  "private": true,
  "license": "Apache-2.0",
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "create-post": "node scripts/create-post.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:tokens": "stylelint \"src/**/*.css\" --fix",
    "audit:html": "htmlhint \"src/**/*.html\" 2>&1 || echo \"No standalone HTML files found; HTML is in JSX — audit skipped\"",
    "audit:biome": "biome check --write src/",
    "audit:a11y": "playwright test e2e/design-audit-pipeline.spec.ts",
    "audit:visual": "playwright test e2e/design-audit-pipeline.spec.ts --grep visual-regression",
    "audit:report": "node scripts/audit-report.mjs",
    "audit:design": "node scripts/audit-report.mjs"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@observablehq/plot": "^0.6.17",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/router-plugin": "^1.167.28",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "motion": "^12.42.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.3.4",
    "vite-plugin-wasm": "^3.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.2",
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.9",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^17.7.0",
    "htmlhint": "^1.9.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "simple-icons": "^16.25.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "esbuild": "^0.28.1",
    "rollup": "^4.62.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
