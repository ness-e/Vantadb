{
  "mcpServers": {
    "vantadb": {
      "command": "vanta-server",
      "args": [
        "--mcp",
        "--path",
        "${workspaceFolder}/.vantadb"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "VANTADB_NAMESPACE": "project-${workspaceFolderBasename}"
      }
    }
  }
}
