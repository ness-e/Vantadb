{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["C:\\Users\\Eros\\.agents\\ponytail\\.opencode\\plugins\\ponytail.mjs"],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "discord": {
      "type": "local",
      "command": [
        "pwsh",
        "-NoProfile",
        "-Command",
        "$t = (Get-Content '.env.tokens' | Where-Object {$_ -match '^DISCORD_BOT_TOKEN=\"(.+)\"$'} | ForEach-Object {$Matches[1]}); $env:DISCORD_TOKEN = $t; npx --yes @rayenking/discord-mcp"
      ],
      "enabled": true
    }
  }
}
