# ── VantaDB Environment Configuration ───────────────────────────────────────
# Renombra este archivo a `.env` o exporta las variables en tu entorno.
# Fuente completa: docs/operations/CONFIGURATION.md
# ──────────────────────────────────────────────────────────────────────────

# ── Almacenamiento ────────────────────────────────────────────────────────
# Ruta de almacenamiento principal. Por defecto: "vantadb_data" (server).
# VANTADB_STORAGE_PATH="./vantadb_data"

# Backend de almacenamiento KV. Por defecto: "fjall". Alternativas: "rocksdb", "memory".
# VANTA_BACKEND="fjall"

# ── Red y Binding (HTTP / TLS) ────────────────────────────────────────────
# VANTADB_HOST="127.0.0.1"   (fallback: HOST)
# VANTADB_PORT="8080"        (fallback: PORT)

# Activa HTTPS configurando las siguientes variables (requiere feature "tls"):
# VANTADB_TLS_CERT="/etc/ssl/certs/vanta.crt"
# VANTADB_TLS_KEY="/etc/ssl/private/vanta.key"

# ── Seguridad y Autenticación ─────────────────────────────────────────────
# Token Bearer para autenticación HTTP. Sin valor por defecto (desactivada).
# VANTADB_API_KEY="super_secret_token_123"

# ── Rate Limiting (Protección Anti-DDoS) ──────────────────────────────────
# Límite de peticiones por minuto. Por defecto: 100.
# VANTADB_RATE_LIMIT_RPM="100"

# ── Hilos y Concurrencia ─────────────────────────────────────────────────
# Máximo de hilos para el thread pool bloqueante. Por defecto: 16.
# VANTADB_MAX_BLOCKING_THREADS="16"

# Timeout del lock de inserción HNSW en ms. Por defecto: 2000.
# VANTADB_INSERT_LOCK_TIMEOUT_MS="2000"

# Timeout del archivo .vanta.lock en ms. Por defecto: 1000.
# VANTADB_FILE_LOCK_TIMEOUT_MS="1000"

# ── WAL (Write-Ahead Log) ─────────────────────────────────────────────────
# Número de archivos shard del WAL (round-robin). Por defecto: 4.
# VANTADB_WAL_SHARDS="4"

# Tamaño del buffer WAL por shard en bytes. Por defecto: 65536 (64KB).
# VANTADB_WAL_BUFFER_SIZE="65536"

# Auto-flush tras N nodos insertados. Por defecto: 10000; vacío = desactivado.
# VANTADB_FLUSH_THRESHOLD="10000"

# ── Prefetch y Memoria ────────────────────────────────────────────────────
# Estrategia de prefetch para MMap. Por defecto: "Auto". Alternativas: "Enabled", "Disabled".
# Alternativa: VANTA_DISABLE_PREFETCH="1" para deshabilitar.
# VANTA_PREFETCH="Auto"

# ── Observabilidad (Logs y OpenTelemetry) ─────────────────────────────────
# Formatea logs en JSON (equivalente a VANTADB_LOG_FORMAT="json"):
# VANTADB_LOG_JSON="1"

# Formato de log. Por defecto: "compact". Alternativas: "json", "full".
# VANTADB_LOG_FORMAT="compact"

# Endpoint del recolector OTLP (requiere feature "opentelemetry"):
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"

# Nombre del servicio para identificación en trazas. Por defecto: "vantadb-server".
# OTEL_SERVICE_NAME="vantadb-server"

# Tracing filter. Por defecto: "info". Ej: "debug", "vantadb=debug".
# RUST_LOG="info"

# ── CLI ───────────────────────────────────────────────────────────────────
# Ruta por defecto para la base de datos en comandos CLI. Por defecto: "./db".
# VANTA_DB="./db"

# ── LLM / Embeddings Remotos (requiere feature "remote-inference") ────────
# Endpoint de Ollama para embeddings remotos. Por defecto: "http://localhost:11434".
# VANTA_LLM_URL="http://localhost:11434"

# Modelo para generar embeddings. Por defecto: "all-minilm".
# VANTA_LLM_MODEL="all-minilm"

# Modelo para summarización. Por defecto: "llama3".
# VANTA_LLM_SUMMARIZE_MODEL="llama3"
